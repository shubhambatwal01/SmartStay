<%- include('../partials/head') %>

    <body>
        <header>
            <%- include('../partials/nav') %>
        </header>
        <main class="min-h-screen mt-32">
            <!-- heading -->
            <h1 class="text-2xl font-bold text-center text-blue-600 mb-6">
                <%= editing ? "Edit" : "Register" %> Your Home Here!
            </h1>
            <div class="flex justify-center">
                <form action="<%= editing ? '/host/edit-home' : '/host/add-home' %>" method="POST"
                    class="bg-white p-8 rounded shadow-md w-full max-w-md">
                    <div class="mb-6">
                        <!-- Hidden ID Field -->
                        <input type="hidden" name="id" value="<%= editing ? home._id : '' %>">
                        <!-- House Name -->
                        <label for="houseName" class="block text-gray-700 font-semibold m-2">House Name</label>
                        <input type="text" id="houseName" name="houseName" value="<%= editing ? home.houseName : '' %>"
                            placeholder="Enter the Name of your house" required
                            class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
                        <!-- House Address -->
                        <label for="houseAddr" class="block text-gray-700 font-semibold m-2">House Address</label>
                        <input type="text" id="houseAddr" name="houseAddr" value="<%= editing ? home.houseAddr : '' %>"
                            placeholder="Enter the Address of your house" required
                            class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
                        <!-- House Price -->
                        <label for="housePrice" class="block text-gray-700 font-semibold m-2">House price</label>
                        <input type="number" id="housePrice" name="housePrice"
                            value="<%= editing ? home.housePrice : '' %>" placeholder="Enter the price of your house"
                            required
                            class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
                        <!-- House Image -->
                        <label for="houseImg" class="block text-gray-700 font-semibold m-2">House Image URL</label>
                        <input type="url" id="houseImg" name="houseImg" value="<%= editing ? home.houseImg : '' %>"
                            placeholder="Enter the image URL of your house" required
                            class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
                        <!-- House Description -->
                        <label for="houseDesc" class="block text-gray-700 font-semibold m-2">House Description</label>
                        <input type="text" id="houseDesc" name="houseDesc" value="<%= editing ? home.houseDesc : '' %>"
                            placeholder="Enter the Description of your house" required
                            class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    </div>
                    <!-- submit button -->
                    <input type="submit" value="<%= editing ? 'Update Home' : 'Add Home' %>"
                        class="w-full bg-[#ff5a5f] hover:bg-[#ff4b51] text-white font-bold py-2 px-4 rounded  transition-colors">
                </form>
            </div>
        </main>
        <!-- Footer -->
        <%- include('../partials/footer') %>
    </body>

    </html>