<nav class="bg-[#FF5A5F] px-6 py-8 flex items-center fixed top-0 w-full ">
    <!-- SmartStay Heart Icon -->
    <a href="/">
        <svg class="w-6 h-6 mr-0 fill-white flex-shrink-0" xmlns="http://www.w3.org/2000/svg" href="/"
            viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
                d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41 0.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
        </svg>
    </a>
    <!-- SmartStay Text -->
    <a href="/" class="text-white font-bold text-xl select-none">SmartStay</a>

    <!-- Navigation Links -->
    <div class="hidden md:flex ml-auto items-center">
    <ul class="flex flex-row items-center gap-3">
        <% if(isLoggedIn) { %>
            <% if(user && user.userType==="user" ) { %>
                <li>
                    <a href="/homes"
                        class="inline-flex items-center justify-center min-w-[120px] text-center text-white font-semibold hover:bg-[#ff4b51] py-2.5 px-5 rounded-lg shadow-sm transition-all duration-200 <%= (currentPage === 'homeList' || currentPage === 'home-detail') ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                        HOME
                    </a>
                </li>

                <li>
                    <a href="/favourite-list"
                        class="inline-flex items-center justify-center min-w-[120px] text-center text-white font-semibold hover:bg-[#ff4b51] py-2.5 px-5 rounded-lg shadow-sm transition-all duration-200 <%= currentPage === 'favourites' ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                        FAVOURITES
                    </a>
                </li>

                <li>
                    <a href="/bookings"
                        class="inline-flex items-center justify-center min-w-[120px] text-center text-white font-semibold hover:bg-[#ff4b51] py-2.5 px-5 rounded-lg shadow-sm transition-all duration-200 <%= currentPage === 'bookings' ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                        BOOKINGS
                    </a>
                </li>

            <% } else if(user && user.userType==="admin" ) { %>

                <li>
                    <a href="/host/host-home"
                        class="inline-flex items-center justify-center min-w-[120px] text-center text-white font-semibold hover:bg-[#ff4b51] py-2.5 px-5 rounded-lg shadow-sm transition-all duration-200 <%= currentPage === 'host-home' ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                        HOST HOME
                    </a>
                </li>

                <li>
                    <a href="/host/add-home"
                        class="inline-flex items-center justify-center min-w-[120px] text-center text-white font-semibold hover:bg-[#ff4b51] py-2.5 px-5 rounded-lg shadow-sm transition-all duration-200 <%= currentPage === 'addHome' ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                        ADD HOME
                    </a>
                </li>

            <% } %>
        <% } %>

        <% if(!isLoggedIn) { %>

            <li>
                <a href="/signup"
                    class="inline-flex items-center justify-center min-w-[120px] text-center text-white font-semibold hover:bg-[#ff4b51] py-2.5 px-5 rounded-lg shadow-sm transition-all duration-200 <%= currentPage === 'signup' ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                    SIGN UP
                </a>
            </li>

            <li>
                <a href="/login"
                    class="inline-flex items-center justify-center min-w-[120px] text-center text-white font-semibold hover:bg-[#ff4b51] py-2.5 px-5 rounded-lg shadow-sm transition-all duration-200 <%= currentPage === 'login' ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                    LOGIN
                </a>
            </li>

        <% } else { %>

            <li>
                <form action="/logout" method="POST">
                    <button type="submit"
                        class="inline-flex items-center justify-center min-w-[120px] text-center text-white font-semibold hover:bg-[#ff4b51] py-2.5 px-5 rounded-lg shadow-sm transition-all duration-200 <%= currentPage === 'login' ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                        LOGOUT
                    </button>
                </form>
            </li>

        <% } %>
    </ul>
</div>
    <!-- Mobile Hamburger -->
    <div class="md:hidden ml-auto">
        <button id="menu-btn" class="focus:outline-none">
            <!-- Hamburger Icon -->
            <svg class="w-6 h-6 " fill="none" stroke="currentColor" viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16">
                </path>
            </svg>
        </button>
    </div>
    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden px-3 py-3 font-semibold">
    <ul class="flex flex-col gap-3">

        <% if(isLoggedIn) { %>

            <% if(user && user.userType==="user" ) { %>

                <li>
                    <a href="/homes"
                        class="flex items-center justify-center w-full text-center text-white font-semibold hover:bg-[#ff4b51] py-3 px-4 rounded-lg shadow-sm transition-all duration-200 <%= (currentPage === 'homeList' || currentPage === 'home-detail') ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                        HOME
                    </a>
                </li>

                <li>
                    <a href="/favourite-list"
                        class="flex items-center justify-center w-full text-center text-white font-semibold hover:bg-[#ff4b51] py-3 px-4 rounded-lg shadow-sm transition-all duration-200 <%= currentPage === 'favourites' ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                        FAVOURITES
                    </a>
                </li>

                <li>
                    <a href="/bookings"
                        class="flex items-center justify-center w-full text-center text-white font-semibold hover:bg-[#ff4b51] py-3 px-4 rounded-lg shadow-sm transition-all duration-200 <%= currentPage === 'bookings' ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                        BOOKINGS
                    </a>
                </li>

            <% } else if(user && user.userType==="admin" ) { %>

                <li>
                    <a href="/host/host-home"
                        class="flex items-center justify-center w-full text-center text-white font-semibold hover:bg-[#ff4b51] py-3 px-4 rounded-lg shadow-sm transition-all duration-200 <%= currentPage === 'host-home' ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                        HOST HOME
                    </a>
                </li>

                <li>
                    <a href="/host/add-home"
                        class="flex items-center justify-center w-full text-center text-white font-semibold hover:bg-[#ff4b51] py-3 px-4 rounded-lg shadow-sm transition-all duration-200 <%= currentPage === 'addHome' ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                        ADD HOME
                    </a>
                </li>

            <% } %>

        <% } %>

        <% if(!isLoggedIn) { %>

            <li>
                <a href="/signup"
                    class="flex items-center justify-center w-full text-center text-white font-semibold hover:bg-[#ff4b51] py-3 px-4 rounded-lg shadow-sm transition-all duration-200 <%= currentPage === 'signup' ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                    SIGN UP
                </a>
            </li>

            <li>
                <a href="/login"
                    class="flex items-center justify-center w-full text-center text-white font-semibold hover:bg-[#ff4b51] py-3 px-4 rounded-lg shadow-sm transition-all duration-200 <%= currentPage === 'login' ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                    LOGIN
                </a>
            </li>

        <% } else { %>

            <li>
                <form action="/logout" method="POST">
                    <button type="submit"
                        class="flex items-center justify-center w-full text-center text-white font-semibold hover:bg-[#ff4b51] py-3 px-4 rounded-lg shadow-sm transition-all duration-200 <%= currentPage === 'login' ? 'bg-[#ff4b51]' : 'bg-[#ff5a5f]' %>">
                        LOGOUT
                    </button>
                </form>
            </li>

        <% } %>

    </ul>
</div>
    <script>
        // Toggle mobile menu
        const menuBtn = document.getElementById("menu-btn");
        const mobileMenu = document.getElementById("mobile-menu");

        menuBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            mobileMenu.classList.toggle("hidden");
        });

        // Close menu when clicking anywhere outside the menu and button
        document.addEventListener("click", (e) => {
            const isClickInsideMenu = mobileMenu.contains(e.target);
            const isClickOnButton = menuBtn.contains(e.target);
            
            if (!isClickInsideMenu && !isClickOnButton && !mobileMenu.classList.contains("hidden")) {
                mobileMenu.classList.add("hidden");
            }
        });
    </script>
</nav>