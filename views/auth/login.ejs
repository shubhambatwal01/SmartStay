<%- include('../partials/head') %>

    <body>
        <header>
            <%- include('../partials/nav') %>
        </header>
        <main class="min-h-screen mt-32">
            <!-- heading -->
            <h1 class="text-2xl font-bold text-center text-blue-600 mb-6">
                Login to Your Account
            </h1>

            <div class="flex justify-center">
                <form action="/login" method="POST" class="bg-white p-8 rounded shadow-md w-full max-w-md">
                    <!-- error messages -->
                    <%- include('../partials/errors') %>
                        <div class="mb-6">
                            <!-- Email Address -->
                            <label for="email" class="block text-gray-700 font-semibold m-2">Email</label>
                            <input type="email" id="email" name="email" placeholder="Enter your Email"
                                value="<%= oldInput.email || '' %>" required
                                class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
                            <!-- Password -->
                            <label for="password" class="block text-gray-700 font-semibold m-2">Password</label>
                            <input type="password" id="password" name="password" placeholder="Enter your Password"
                                required
                                class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />

                        </div>
                        <!-- Login button -->
                        <input type="submit" value="Login"
                            class="w-full bg-[#ff5a5f] hover:bg-[#ff4b51] text-white font-bold py-2 px-4 rounded  transition-colors mb-3">
                        <div class="text-center">
                            <span>Don't have an account?</span>
                            <a href="/signup" class="text-blue-600 underline">Sign up here</a>
                        </div>
                </form>
            </div>
        </main>
        <!-- Footer -->
        <%- include('../partials/footer') %>
    </body>

    </html>