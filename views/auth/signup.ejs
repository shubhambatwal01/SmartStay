<%- include('../partials/head') %>

    <body>
        <header>
            <%- include('../partials/nav') %>
        </header>
        <main class="min-h-screen mt-28">

            <!-- heading -->
            <h1 class="text-2xl font-bold text-center text-blue-600 mb-6">
                Sign Up for a New Account
            </h1>

            <div class="flex justify-center">
                <form action="/signup" method="POST" class="bg-white p-8 rounded shadow-md w-full max-w-md">

                    <!-- Error Messages -->
                    <%- include('../partials/errors') %>
                    
                        <div class="mb-6">
                            <!-- Your Name -->
                            <label for="fullName" class="block text-gray-700 font-semibold m-2">Full
                                Name</label>
                            <input type="text" id="fullName" name="fullName" placeholder="Enter your Full Name"
                                value="<%= oldInput.fullName || '' %>" required
                                class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
                        </div>

                        <div class="mb-6">
                            <!-- Email Address -->
                            <label for="email" class="block text-gray-700 font-semibold m-2">Email</label>
                            <input type="email" id="email" name="email" placeholder="Enter your Email" required
                                value="<%= oldInput.email || '' %>"
                                class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
                        </div>

                        <div class="grid gap-6 md:grid-cols-2 mb-6">
                            <div>
                                <label for="password" class="block text-gray-700 font-semibold m-2">Password</label>
                                <input type="password" id="password" name="password" placeholder="Enter your Password"
                                    required
                                    class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
                            </div>
                            <div>
                                <label for="confirmPassword" class="block text-gray-700 font-semibold m-2">Confirm
                                    Password</label>
                                <input type="password" id="confirmPassword" name="confirmPassword"
                                    placeholder="Confirm your Password" required
                                    class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
                            </div>
                        </div>

                        <div class="mb-6">
                            <label class="block text-gray-700 font-semibold m-2">User Type</label>
                            <div class="flex gap-2 ml-2">
                                <label class="flex items-center gap-2">
                                    <input type="radio" id="userCheck" name="userType" value="user"
                                        class="h-4 w-4 text-blue-600" <%=oldInput.userType==='user' ? 'checked' : '' %>
                                    />
                                    <span>User</span>
                                </label>
                                <label class="flex items-center gap-2">
                                    <input type="radio" id="adminCheck" name="userType" value="admin"
                                        class="h-4 w-4 text-blue-600" <%=oldInput.userType==='admin' ? 'checked' : '' %>
                                    />
                                    <span>Admin</span>
                                </label>
                            </div>
                        </div>

                        <div class="mb-6">
                            <label class="flex items-center gap-3 text-gray-700 font-semibold">
                                <input type="checkbox" name="terms" required class="form-checkbox h-5 w-5 text-blue-600"
                                    <%=oldInput.terms ? 'checked' : '' %> />
                                <span>I agree to the <a href="#" class="text-blue-600 underline">Terms and
                                        Conditions</a></span>
                            </label>
                        </div>

                        <div class="mb-6">
                            <input type="submit" value="Sign Up"
                                class="w-full bg-[#ff5a5f] hover:bg-[#ff4b51] text-white font-bold py-2 px-4 rounded transition-colors" />
                        </div>
                        <div class="text-center">
                            <span>Already have an account?</span>
                            <a href="/login" class="text-blue-600 underline">Login here</a>
                        </div>
                </form>
            </div>
        </main>
        <!-- Footer -->
        <%- include('../partials/footer') %>
    </body>

    </html>